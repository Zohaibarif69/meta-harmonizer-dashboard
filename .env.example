# MetaHarmonizer Environment Configuration
# Copy this file to .env.local and update values for your environment

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# API Settings
API_TITLE=MetaHarmonizer Curator API
API_VERSION=1.0.0
API_DESCRIPTION=REST API for metadata field curation workflow
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Database
DATABASE_URL=sqlite:///./backend/curator_workflow.db

# CORS Settings (allow frontend to communicate)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# File Paths
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports

# Mapper Configuration
MAPPER_CONFIDENCE_THRESHOLD=0.7
MAPPER_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/curator_api.log

# Feature Flags
AUTO_SUGGESTIONS_ENABLED=true
BULK_OPERATIONS_ENABLED=true
AUDIT_TRAIL_ENABLED=true

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000

# Feature Flags
REACT_APP_ENABLE_AUTO_SUGGEST=true
REACT_APP_ENABLE_KEYBOARD_SHORTCUTS=true
REACT_APP_ENABLE_BULK_APPROVE=true

# Display Settings
REACT_APP_PAGE_SIZE=20
REACT_APP_AUTO_REFRESH_INTERVAL=10000

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Node environment
NODE_ENV=development

# Python environment (for backend development)
PYTHON_VERSION=3.8

# Testing
JEST_ENVIRONMENT=jsdom
