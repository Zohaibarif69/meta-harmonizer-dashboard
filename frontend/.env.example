# MetaHarmonizer Dashboard Environment Variables
# Copy this file to .env.local and fill in actual values

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000

# Metrics File Path (relative to MetaHarmonizer directory)
REACT_APP_METRICS_FILE_PATH=../MetaHarmonizer/mapper_evaluation_metrics.json

# Feature Flags
REACT_APP_ENABLE_EXPORT=true
REACT_APP_ENABLE_LIVE_UPDATES=false

# Debug Mode
REACT_APP_DEBUG=false
