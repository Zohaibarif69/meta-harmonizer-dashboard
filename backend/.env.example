# Application Settings
APP_NAME=MetaHarmonizer Backend
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server Settings
HOST=127.0.0.1
PORT=8000

# Feature Flags
ENABLE_MAPPER_EXECUTION=True
ENABLE_METRICS_EVALUATION=True
ENABLE_CACHING=True
ENABLE_WEB_UI=True

# Mapper Settings
DEFAULT_MAPPER_METHOD=rag
MAPPER_TIMEOUT=300
MAPPER_BATCH_SIZE=100

# Cache Settings
CACHE_ENABLED=True
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# CORS Settings (for frontend communication)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=backend.log
